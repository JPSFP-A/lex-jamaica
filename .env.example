# ============================================================
# LexJamaica — Environment variables
# Copy to .env.local for local dev (never commit real values)
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

# Public anon key (safe to expose in browser)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Service role key — NEVER expose in browser, only in Edge Functions
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── Supabase Storage ──────────────────────────────────────────
# Create a bucket named "documents" in Supabase Storage
# Set it to private (signed URLs for download)
STORAGE_BUCKET=documents
